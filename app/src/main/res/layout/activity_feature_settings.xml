<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tv_app_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_screen_title"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/app_description"
            android:textColor="#666666"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="#F3F4F6"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tv_top_spacer_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/top_spacer_title"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/top_spacer_description"
                android:textColor="#666666"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_top_spacer_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textSize="16sp"
                android:textStyle="bold" />

            <SeekBar
                android:id="@+id/seek_top_spacer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp" />

            <TextView
                android:id="@+id/tv_max_visible_events_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/max_visible_events_title"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/max_visible_events_description"
                android:textColor="#666666"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_max_visible_events_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textSize="16sp"
                android:textStyle="bold" />

            <SeekBar
                android:id="@+id/seek_max_visible_events"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="#F3F4F6"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/color_settings_title"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/color_settings_description"
                android:textColor="#666666"
                android:textSize="14sp" />

            <LinearLayout
                android:id="@+id/row_color_background"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingVertical="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/color_background_label"
                    android:textSize="15sp" />

                <View
                    android:id="@+id/view_color_background"
                    android:layout_width="36dp"
                    android:layout_height="36dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_color_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingVertical="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/color_panel_label"
                    android:textSize="15sp" />

                <View
                    android:id="@+id/view_color_panel"
                    android:layout_width="36dp"
                    android:layout_height="36dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_color_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingVertical="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/color_header_label"
                    android:textSize="15sp" />

                <View
                    android:id="@+id/view_color_header"
                    android:layout_width="36dp"
                    android:layout_height="36dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_color_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingVertical="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/color_card_label"
                    android:textSize="15sp" />

                <View
                    android:id="@+id/view_color_card"
                    android:layout_width="36dp"
                    android:layout_height="36dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_color_accent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingVertical="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/color_accent_label"
                    android:textSize="15sp" />

                <View
                    android:id="@+id/view_color_accent"
                    android:layout_width="36dp"
                    android:layout_height="36dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_color_due_today"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingVertical="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/color_due_today_label"
                    android:textSize="15sp" />

                <View
                    android:id="@+id/view_color_due_today"
                    android:layout_width="36dp"
                    android:layout_height="36dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_color_done_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingVertical="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/color_done_card_label"
                    android:textSize="15sp" />

                <View
                    android:id="@+id/view_color_done_card"
                    android:layout_width="36dp"
                    android:layout_height="36dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_color_done_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingVertical="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/color_done_text_label"
                    android:textSize="15sp" />

                <View
                    android:id="@+id/view_color_done_text"
                    android:layout_width="36dp"
                    android:layout_height="36dp" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_save_colors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/save_colors_button" />

            <Button
                android:id="@+id/btn_reset_colors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/reset_colors_button" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="#F3F4F6"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tv_user_uuid_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/user_uuid_title"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/user_uuid_description"
                android:textColor="#666666"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/et_user_uuid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="#FFFFFF"
                android:hint="@string/user_uuid_hint"
                android:inputType="textPassword"
                android:maxLines="1"
                android:padding="12dp"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btn_save_user_uuid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/save_user_uuid_button"
                android:textSize="16sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_apply_wallpaper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:layout_marginBottom="14dp"
            android:text="@string/apply_wallpaper_button"
            android:textSize="18sp" />
    </LinearLayout>
</ScrollView>
